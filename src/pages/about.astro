---
import { SITE } from 'astrowind:config';
import { getPermalink, getHomePermalink } from '~/utils/permalinks';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const home = getHomePermalink();
const brand = SITE?.name ?? 'Our service';
const cl = 'text-primary font-medium hover:underline';

const metadata = {
  title: 'About us',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->

  <Hero
    tagline="About us"
    image={{
      src: 'https://images.unsplash.com/photo-1593359677879-a4bb92f829d1?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Premium IPTV streaming at home',
    }}
  >
    <Fragment slot="title">
      We deliver <span class="text-accent dark:text-white">premium IPTV</span> so you can watch what you love
    </Fragment>

    <Fragment slot="subtitle">
      <a href={home} class={cl}>{brand}</a> delivers reliable streams, flexible plans, and support you can count on. Live TV, sports, movies, and series in one place. <a href={getPermalink('/pricing')} class={cl}>View our plans</a>, <a href={`${home}#features`} class={cl}>see features</a>, or <a href={getPermalink('/contact')} class={cl}>get in touch</a>. <a href={`${home}#pricing`} class={cl}>Pricing</a> · <a href={`${home}#faqs`} class={cl}>FAQ</a>.
    </Fragment>
  </Hero>

  <!-- Stats -->

  <Stats
    title="Our service in numbers"
    stats={[
      { title: 'Channels', amount: '+49K' },
      { title: 'Categories', amount: '+1K' },
      { title: 'Servers', amount: '+30' },
      { title: 'Satisfied clients', amount: '10K' },
    ]}
  />

  <!-- What we offer -->

  <Features3
    title="What we offer"
    subtitle={'<a href="' + home + '" class="' + cl + '">' + brand + '</a> brings you live TV, sports, movies, and series in HD. One subscription, every device. See our <a href="' + getPermalink('/pricing') + '" class="' + cl + '">pricing</a>, <a href="' + home + '#pricing" class="' + cl + '">plans</a>, or <a href="' + getPermalink('/contact') + '" class="' + cl + '">contact us</a>.'}
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Sports & events',
        description:
          'Premier League, La Liga, Serie A, and more. Watch live in HD. <a href="' + home + '#features" class="' + cl + '">Our features</a> · <a href="' + home + '#pricing" class="' + cl + '">Plans</a>.',
        icon: 'tabler:device-tv',
      },
      {
        title: 'Series & movies',
        description:
          'Thousands of series and movies in one place. <a href="' + home + '" class="' + cl + '">' + brand + '</a> · <a href="' + getPermalink('/pricing') + '" class="' + cl + '">View plans</a>.',
        icon: 'tabler:movie',
      },
      {
        title: 'All devices',
        description:
          'Smart TV, Android, iOS, Fire Stick, and more. One subscription, unlimited screens. <a href="' + home + '#how-to-activate" class="' + cl + '">How to activate</a> · <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact</a>.',
        icon: 'tabler:devices',
      },
    ]}
  />

  <!-- Why choose us -->

  <Features3
    title="Why choose us"
    subtitle={'<a href="' + home + '" class="' + cl + '">' + brand + '</a> focuses on reliability, support, and fair pricing. <a href="' + home + '#pricing" class="' + cl + '">See plans</a> and <a href="' + getPermalink('/contact') + '" class="' + cl + '">contact us</a>.'}
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'HD & 4K quality',
        description:
          'Crystal-clear picture with full HD and 4K support. <a href="' + home + '#features" class="' + cl + '">Features</a> · <a href="' + getPermalink('/pricing') + '" class="' + cl + '">Plans</a>.',
        icon: 'tabler:video',
      },
      {
        title: 'Instant activation',
        description:
          'Credentials sent by email or WhatsApp right after payment. <a href="' + home + '#how-to-activate" class="' + cl + '">How to activate</a>. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact</a>.',
        icon: 'tabler:bolt',
      },
      {
        title: 'No contract',
        description:
          'Flexible plans with no long-term lock-in. <a href="' + home + '#pricing" class="' + cl + '">View plans</a> · <a href="' + home + '#faqs" class="' + cl + '">FAQ</a>.',
        icon: 'tabler:calendar-off',
      },
      {
        title: 'Satisfaction or refund',
        description:
          'We stand behind our service. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact us</a> with any concerns. <a href="' + home + '" class="' + cl + '">' + brand + '</a> has you covered.',
        icon: 'tabler:shield-check',
      },
      {
        title: '24/7 support',
        description:
          'Questions or issues? <a href="' + getPermalink('/contact') + '" class="' + cl + '">Our team</a> is available around the clock via WhatsApp. <a href="' + home + '#faqs" class="' + cl + '">FAQs</a>.',
        icon: 'tabler:headset',
      },
      {
        title: 'Secure payment',
        description:
          'Pay with card, PayPal, or bank transfer. <a href="' + getPermalink('/pricing') + '" class="' + cl + '">Pricing</a> · <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact</a>.',
        icon: 'tabler:lock',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1593359677879-a4bb92f829d1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'IPTV streaming',
    }}
  />

  <!-- Our values -->

  <Steps2
    title="Our values"
    subtitle={'<a href="' + home + '" class="' + cl + '">' + brand + '</a> runs on trust, quality, and putting the customer first. <a href="' + getPermalink('/pricing') + '" class="' + cl + '">Plans</a> · <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact</a>.'}
    items={[
      {
        title: 'Customer first',
        description:
          'Your satisfaction guides what we do. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact us</a> anytime. <a href="' + home + '#faqs" class="' + cl + '">FAQ</a>.',
      },
      {
        title: 'Constant improvement',
        description:
          'We keep improving our streams and support. <a href="' + home + '#features" class="' + cl + '">Features</a> · <a href="' + home + '" class="' + cl + '">' + brand + '</a>.',
      },
      {
        title: 'Fair and transparent',
        description:
          'Clear <a href="' + home + '#pricing" class="' + cl + '">pricing</a>, no hidden fees. <a href="' + getPermalink('/pricing') + '" class="' + cl + '">View plans</a>.',
      },
    ]}
  />

  <!-- Achievements -->

  <Steps2
    title="What we’re proud of"
    subtitle={'<a href="' + home + '" class="' + cl + '">' + brand + '</a> works every day to deliver a service you can rely on. <a href="' + getPermalink('/pricing') + '" class="' + cl + '">View plans</a> · <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact</a>.'}
    isReversed={true}
    callToAction={{
      text: 'View plans',
      href: getPermalink('/pricing'),
    }}
    items={[
      {
        title: 'Global service',
        description: 'We serve customers worldwide. <a href="' + home + '#features" class="' + cl + '">Our features</a> · <a href="' + home + '#pricing" class="' + cl + '">Plans</a> · <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact</a>.',
        icon: 'tabler:globe',
      },
      {
        title: 'Trusted by thousands',
        description:
          'Thousands of satisfied clients rely on <a href="' + home + '" class="' + cl + '">' + brand + '</a>. <a href="' + home + '#pricing" class="' + cl + '">See plans</a> and <a href="' + getPermalink('/about') + '" class="' + cl + '">about us</a>.',
        icon: 'tabler:message-star',
      },
      {
        title: 'Reliable and stable',
        description:
          'We invest in robust servers and quality streams. <a href="' + home + '#how-to-activate" class="' + cl + '">How to activate</a> · <a href="' + getPermalink('/contact') + '" class="' + cl + '">Support</a>.',
        icon: 'tabler:award',
      },
    ]}
  />

  <!-- Contact us -->

  <Features2
    title="Get in touch"
    tagline="Contact us"
    columns={2}
    items={[
      {
        title: 'WhatsApp',
        description:
          'Fastest way to reach <a href="' + home + '" class="' + cl + '">' + brand + '</a>. Message us for orders, support, or a free trial. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact</a> · <a href="' + home + '#pricing" class="' + cl + '">Plans</a>.',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Contact form',
        description:
          'Prefer email? <a href="' + getPermalink('/contact') + '" class="' + cl + '">Use our contact page</a> and we will get back to you. <a href="' + home + '#faqs" class="' + cl + '">FAQ</a> · <a href="' + getPermalink('/pricing') + '" class="' + cl + '">Pricing</a>.',
        icon: 'tabler:mail',
      },
    ]}
  />
</Layout>
