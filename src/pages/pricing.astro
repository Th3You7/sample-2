---
import { SITE } from 'astrowind:config';
import { getPermalink, getHomePermalink } from '~/utils/permalinks';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';

const home = getHomePermalink();
const brand = SITE?.name ?? 'Our service';
const cl = 'text-primary font-medium hover:underline';

const metadata = {
  title: 'Pricing',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Plans"
    title="Choose your plan"
    subtitle={'<a href="' + home + '" class="' + cl + '">' + brand + '</a> plans: same features, more savings the longer you subscribe. <a href="' + getPermalink('/about') + '" class="' + cl + '">Learn about our service</a>, see our <a href="' + home + '#features" class="' + cl + '">features</a>, or <a href="https://wa.me/212780761806" class="' + cl + '">contact us for a free trial</a>. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact</a>.'}
  />

  <!-- Pricing Widget ******************* -->

  <Prices
    id="pricing"
    title=""
    subtitle=""
    prices={[
      {
        title: 'Monthly',
        subtitle: '',
        price: 17,
        period: '/month',
        items: [
          { description: '50,000+ channels' },
          { description: 'No freeze' },
          { description: 'Free guidance' },
          { description: 'FHD, 4K, 8K' },
          { description: 'All devices' },
          { description: 'Privacy protection & built-in VPN' },
          { description: 'Free auto updates' },
          { description: 'Anti-freeze TM 9.8 technology' },
          { description: 'Available EPG' },
          { description: '24/7 support' },
        ],
        callToAction: { text: 'Buy now', href: 'https://wa.me/212780761806' },
      },
      {
        title: '3 Months',
        subtitle: 'Save 17%',
        price: 37,
        period: '/3 months',
        items: [
          { description: '50,000+ channels' },
          { description: 'No freeze' },
          { description: 'Free guidance' },
          { description: 'FHD, 4K, 8K' },
          { description: 'All devices' },
          { description: 'Privacy protection & built-in VPN' },
          { description: 'Free auto updates' },
          { description: 'Anti-freeze TM 9.8 technology' },
          { description: 'Available EPG' },
          { description: '24/7 support' },
        ],
        callToAction: { text: 'Buy now', href: 'https://wa.me/212780761806' },
      },
      {
        title: '6 Months',
        subtitle: 'Save 25%',
        price: 49,
        period: '/6 months',
        items: [
          { description: '50,000+ channels' },
          { description: 'No freeze' },
          { description: 'Free guidance' },
          { description: 'FHD, 4K, 8K' },
          { description: 'All devices' },
          { description: 'Privacy protection & built-in VPN' },
          { description: 'Free auto updates' },
          { description: 'Anti-freeze TM 9.8 technology' },
          { description: 'Available EPG' },
          { description: '24/7 support' },
        ],
        callToAction: { text: 'Buy now', href: 'https://wa.me/212780761806' },
        hasRibbon: true,
        ribbonTitle: 'Popular',
      },
      {
        title: 'Yearly',
        subtitle: 'Save 33%',
        price: 67,
        period: '/year',
        items: [
          { description: '50,000+ channels' },
          { description: 'No freeze' },
          { description: 'Free guidance' },
          { description: 'FHD, 4K, 8K' },
          { description: 'All devices' },
          { description: 'Privacy protection & built-in VPN' },
          { description: 'Free auto updates' },
          { description: 'Anti-freeze TM 9.8 technology' },
          { description: 'Available EPG' },
          { description: '24/7 support' },
        ],
        callToAction: { text: 'Buy now', href: 'https://wa.me/212780761806' },
      },
    ]}
  />

  <!-- Service features -->

  <Features3
    title="What you get with every plan"
    subtitle={'All <a href="' + home + '" class="' + cl + '">' + brand + '</a> plans include the same features. Pick the duration that suits you. See <a href="' + home + '#pricing" class="' + cl + '">plans on home</a> or <a href="' + getPermalink('/about') + '" class="' + cl + '">about us</a>.'}
    columns={2}
    items={[
      {
        title: 'Flexible plan lengths',
        description: 'Choose monthly, 3 months, 6 months, or yearly. The longer you subscribe, the more you save—no lock-in. <a href="' + home + '#pricing" class="' + cl + '">View plans</a>.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Transparent pricing',
        description: 'The price you see is what you pay. No hidden fees. All plans include the same channels and features. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact us</a> with questions.',
        icon: 'tabler:receipt',
      },
      {
        title: 'Secure payments',
        description: 'Pay safely with credit card, PayPal, or bank transfer. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact support</a> to complete your order. See <a href="' + home + '#faqs" class="' + cl + '">FAQ</a>.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Instant activation',
        description: 'Your credentials are sent by email or WhatsApp shortly after payment. <a href="' + home + '#how-to-activate" class="' + cl + '">How to activate</a>. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Need help?</a>',
        icon: 'tabler:bolt',
      },
      {
        title: 'Same features, every plan',
        description: '50,000+ channels, FHD/4K, all devices, EPG, and 24/7 support. <a href="' + home + '#features" class="' + cl + '">Our features</a>. Only duration and price change.',
        icon: 'tabler:device-tv',
      },
      {
        title: '24/7 support',
        description: 'Questions about your plan or setup? <a href="' + getPermalink('/contact') + '" class="' + cl + '">Our support</a> is available around the clock via WhatsApp. <a href="' + home + '" class="' + cl + '">' + brand + '</a> is here for you.',
        icon: 'tabler:headset',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- How to get started -->

  <Steps
    title="How to get your IPTV plan"
    tagline="Simple process"
    subtitle={'<a href="' + home + '" class="' + cl + '">' + brand + '</a>: contact us, choose your plan, pay, and start watching. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact</a> · <a href="' + home + '#pricing" class="' + cl + '">Plans</a> · <a href="' + getPermalink('/about') + '" class="' + cl + '">About</a>.'}
    isReversed={true}
    items={[
      {
        title: 'Contact us',
        description: 'Reach out via WhatsApp or our <a href="' + getPermalink('/contact') + '" class="' + cl + '">contact form</a>. We will help you pick the right <a href="' + home + '#pricing" class="' + cl + '">plan</a> and answer any questions.',
        icon: 'tabler:message-circle',
      },
      {
        title: 'Choose your plan',
        description: 'Select monthly, 3 months, 6 months, or yearly. See <a href="' + home + '#pricing" class="' + cl + '">plans on home</a> or <a href="' + getPermalink('/about') + '" class="' + cl + '">about ' + brand + '</a>. Tell us and we send payment details.',
        icon: 'tabler:credit-card',
      },
      {
        title: 'Pay securely',
        description: 'Pay by card, PayPal, or bank transfer. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact us</a> to complete. Credentials sent after payment. <a href="' + home + '#how-to-activate" class="' + cl + '">How to activate</a>.',
        icon: 'tabler:lock',
      },
      {
        title: 'Start watching',
        description: 'Enter your credentials in your IPTV player and enjoy. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Need help?</a> <a href="' + home + '" class="' + cl + '">' + brand + '</a> is here whenever you need us.',
        icon: 'tabler:player-play',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1593359677879-a4bb92f829d1?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80',
      alt: 'IPTV streaming',
    }}
  />

  <!-- Pricing FAQs -->

  <FAQs
    title="Pricing FAQs"
    subtitle={'Choosing the right plan is important. <a href="' + home + '" class="' + cl + '">' + brand + '</a> answers to common questions about our IPTV plans. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact us</a> · <a href="' + home + '#faqs" class="' + cl + '">More FAQ</a> · <a href="' + getPermalink('/about') + '" class="' + cl + '">About</a>.'}
    columns={1}
    items={[
      {
        title: 'Do the plans come with customer support?',
        description:
          'Yes. All <a href="' + home + '" class="' + cl + '">' + brand + '</a> plans include 24/7 support. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact us</a> via WhatsApp or our contact form for setup, channels, or any issues. See <a href="' + home + '#features" class="' + cl + '">features</a>.',
      },
      {
        title: 'Is there a trial period for the different plans?',
        description:
          'We offer a free trial. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Get in touch</a> and we will set you up—no obligation. Or <a href="' + home + '#pricing" class="' + cl + '">view plans</a> and <a href="' + getPermalink('/about') + '" class="' + cl + '">learn about us</a>.',
      },
      {
        title: 'Can I switch between plans?',
        description:
          'When your current plan ends, you can choose any other plan. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact us</a> before renewal and we will arrange it. <a href="' + home + '#pricing" class="' + cl + '">See plans</a>.',
      },
      {
        title: 'What payment methods do you accept?',
        description:
          'We accept credit card, PayPal, and bank transfer. <a href="' + getPermalink('/contact') + '" class="' + cl + '">Contact our support</a> via WhatsApp to complete your order. <a href="' + home + '#faqs" class="' + cl + '">FAQ</a>.',
      },
      {
        title: 'Are there any hidden fees beyond the displayed cost?',
        description:
          'No. The price shown is what you pay. All <a href="' + home + '" class="' + cl + '">' + brand + '</a> plans include the same features. <a href="' + home + '#features" class="' + cl + '">Features</a> · <a href="' + getPermalink('/about') + '" class="' + cl + '">About us</a>. No hidden fees.',
      },
    ]}
  />
</Layout>
